{
  "collections": [
    {
      "name": "users",
      "description": "用户信息（积分、免广告次数）",
      "properties": [
        {
          "name": "openid",
          "description": "用户openid",
          "type": "string"
        },
        {
          "name": "points",
          "description": "积分数量（整数）",
          "type": "integer",
          "defaultValue": 0
        },
        {
          "name": "ad_free_count",
          "description": "免广告次数",
          "type": "integer",
          "defaultValue": 0
        },
        {
          "name": "total_ads_watched",
          "description": "累计看广告次数",
          "type": "integer",
          "defaultValue": 0
        },
        {
          "name": "total_resources_uploaded",
          "description": "累计上传资源数",
          "type": "integer",
          "defaultValue": 0
        },
        {
          "name": "create_time",
          "description": "创建时间",
          "type": "timestamp"
        },
        {
          "name": "update_time",
          "description": "更新时间",
          "type": "timestamp"
        }
      ],
      "index": [
        {
          "name": "openid_index",
          "fields": ["openid"],
          "unique": true
        }
      ]
    },
    {
      "name": "resources",
      "description": "资源信息",
      "properties": [
        {
          "name": "title",
          "description": "资源标题",
          "type": "string"
        },
        {
          "name": "description",
          "description": "资源描述",
          "type": "string"
        },
        {
          "name": "url",
          "description": "资源链接",
          "type": "string"
        },
        {
          "name": "ad_count",
          "description": "需要看的广告数量（1-3）",
          "type": "integer",
          "defaultValue": 1
        },
        {
          "name": "uploader_openid",
          "description": "上传者openid",
          "type": "string"
        },
        {
          "name": "uploader_nickname",
          "description": "上传者昵称",
          "type": "string"
        },
        {
          "name": "view_count",
          "description": "查看次数",
          "type": "integer",
          "defaultValue": 0
        },
        {
          "name": "feedback_count",
          "description": "反馈次数",
          "type": "integer",
          "defaultValue": 0
        },
        {
          "name": "is_valid",
          "description": "是否有效（null待检测，true有效，false无效）",
          "type": "string",
          "nullable": true
        },
        {
          "name": "create_time",
          "description": "创建时间",
          "type": "timestamp"
        },
        {
          "name": "update_time",
          "description": "更新时间",
          "type": "timestamp"
        }
      ],
      "index": [
        {
          "name": "title_index",
          "fields": ["title"],
          "caseSensitive": false
        },
        {
          "name": "create_time_index",
          "fields": ["create_time"],
          "order": "desc"
        }
      ]
    },
    {
      "name": "feedbacks",
      "description": "反馈记录",
      "properties": [
        {
          "name": "resource_id",
          "description": "资源ID",
          "type": "string"
        },
        {
          "name": "resource_url",
          "description": "资源链接",
          "type": "string"
        },
        {
          "name": "reporter_openid",
          "description": "举报者openid",
          "type": "string"
        },
        {
          "name": "is_valid",
          "description": "检测结果（true有效，false无效）",
          "type": "boolean"
        },
        {
          "name": "status",
          "description": "状态（valid无效，invalid有效，pending检测中）",
          "type": "string"
        },
        {
          "name": "checked_at",
          "description": "检测时间",
          "type": "timestamp"
        },
        {
          "name": "create_time",
          "description": "创建时间",
          "type": "timestamp"
        }
      ],
      "index": [
        {
          "name": "resource_reporter_index",
          "fields": ["resource_id", "reporter_openid"],
          "unique": true
        }
      ]
    },
    {
      "name": "ad_logs",
      "description": "广告观看日志",
      "properties": [
        {
          "name": "user_openid",
          "description": "用户openid",
          "type": "string"
        },
        {
          "name": "ad_id",
          "description": "广告ID（用于防刷）",
          "type": "string"
        },
        {
          "name": "type",
          "description": "类型（earn赚取，refund返还，exchange兑换，use使用）",
          "type": "string"
        },
        {
          "name": "points",
          "description": "积分变化（整数）",
          "type": "integer"
        },
        {
          "name": "ad_free_count",
          "description": "免广告次数变化",
          "type": "integer"
        },
        {
          "name": "reason",
          "description": "原因说明",
          "type": "string"
        },
        {
          "name": "resource_id",
          "description": "关联资源ID（使用/兑换时）",
          "type": "string",
          "nullable": true
        },
        {
          "name": "create_time",
          "description": "创建时间",
          "type": "timestamp"
        }
      ],
      "index": [
        {
          "name": "user_create_time_index",
          "fields": ["user_openid", "create_time"],
          "order": "desc"
        }
      ]
    }
  ]
}
